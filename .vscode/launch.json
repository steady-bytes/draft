{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Gateway",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "internal/gateway/main.go",
            "cwd": "${workspaceFolder}",
            "debugAdapter": "dlv-dap",
            "args": ["run"]
        },
        {
            "name": "Host",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "internal/host/main.go",
            "cwd": "${workspaceFolder}",
            "debugAdapter": "dlv-dap",
        },
        {
            "name": "Blueprint Register Cluster",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "pkg/blueprint-client/main.go",
            "cwd": "${workspaceFolder}",
            "debugAdapter": "dlv-dap",
            "env": {
                "CMD": "register"
            }
        },
        {
            "name": "Blueprint Init",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "pkg/blueprint-client/main.go",
            "cwd": "${workspaceFolder}",
            "debugAdapter": "dlv-dap",
            "env": {
                "CMD": "init"
            }
        },
        {
            "name": "Blueprint_1",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "internal/blueprint/main.go",
            "cwd": "${workspaceFolder}",
            "debugAdapter": "dlv-dap",
            "env": {
                "RAFT_PORT": "1111",
                "NONCE_STR": "test",
                "SERVER_PORT": "2221",
                "RAFT_IP": "localhost",
                "RAFT_NODE_ID": "node_1",
                "BOOTSTRAP_RAFT": "true"
            },  
        },
        {
            "name": "Blueprint_2",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "internal/blueprint/main.go",
            "cwd": "${workspaceFolder}",
            "debugAdapter": "dlv-dap",
            "env": {
                "RAFT_PORT": "1112",
                "RAFT_IP": "localhost",
                "NONCE_STR": "test",
                "SERVER_PORT": "2222",
                "RAFT_NODE_ID": "node_2"
            },  
        },
        {
            "name": "Blueprint_3",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "internal/blueprint/main.go",
            "cwd": "${workspaceFolder}",
            "debugAdapter": "dlv-dap",
            "env": {
                "RAFT_PORT": "1113",
                "RAFT_IP": "localhost",
                "NONCE_STR": "test",
                "SERVER_PORT": "2223",
                "RAFT_NODE_ID": "node_3"
            },  
        }
    ],
    "compounds": [
        {
            "name": "Blueprint Cluster",
            "configurations": [
                "Blueprint_1", "Blueprint_2", "Blueprint_3"
            ],
            "stopAll": true,
        }
    ]
}